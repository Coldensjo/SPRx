{
	"$schema": "https://schema.tauri.app/config/2",
	"productName": "SPRx",
	"version": "0.3.0",
	"identifier": "com.frenvius.sprx.app",
	"build": {
		"beforeDevCommand": "npm run dev",
		"beforeBuildCommand": "npm run build",
		"devUrl": "http://localhost:8090",
		"frontendDist": "../dist"
	},
	"app": {
		"windows": [
			{
				"label": "main",
				"title": "SPRx",
				"width": 1200,
				"height": 780,
				"minWidth": 900,
				"minHeight": 600,
				"resizable": true,
				"fullscreen": false,
				"decorations": false,
				"dragDropEnabled": true,
				"backgroundColor": "#101418"
			}
		],
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": ["nsis"],
		"windows": {
			"nsis": {
				"installerIcon": "icons/icon.ico",
				"installMode": "currentUser"
			}
		},
		"icon": [
			"icons/32x32.png",
			"icons/128x128.png",
			"icons/128x128@2x.png",
			"icons/256x256.png",
			"icons/512x512.png",
			"icons/icon.icns",
			"icons/icon.ico"
		]
	}
}
